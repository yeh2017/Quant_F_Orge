# ── 数据源（必填） ──
TUSHARE_TOKEN=
# Tushare 积分等级（120=免费/2000=基础/5000=进阶），影响可同步的数据范围
# 也可在前端 设置 → 积分等级 中选择
# TUSHARE_POINTS=2000

# ── 服务配置 ──
API_HOST=0.0.0.0
API_PORT=8000
TQDM_DISABLE=1

# ── 数据限速（秒/请求，积分越高可调越小） ──
# TUSHARE_FETCH_SLEEP=0.15
# BOND_FETCH_SLEEP=0.1
# FINANCIAL_SLEEP=0.8
# MONEYFLOW_SLEEP=0.2
# ANALYST_SLEEP=0.1
# SW_INDUSTRY_SLEEP=0.5
# AKSHARE_NEWS_SLEEP=0.5


# ── 并发 & 写入 ──
# FINANCIAL_WORKERS=5
# WRITE_BATCH_SIZE=500

# ── 熔断保护 ──
# TUSHARE_RATE_LIMIT_PER_MIN=480
# TUSHARE_BREAKER_FAIL_THRESHOLD=5
# TUSHARE_BREAKER_COOLDOWN=60.0

# ── 数据保留 ──
# NEWS_RETAIN_DAYS=90
# BACKTEST_RESULT_RETAIN_DAYS=90
# DB_RETAIN_YEARS=7
# CACHE_RETAIN_DAYS=7
# LOG_RETAIN_DAYS=15

# ── 新闻自动抓取（0=关闭，单位：小时） ──
NEWS_AUTO_FETCH_HOURS=4

# ── Tavily 搜索增强（新闻模块，可选） ──
TAVILY_API_KEY=

# ── 推送通知（可选，填入后自动启用） ──
# TELEGRAM_ENABLED=false
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
# TELEGRAM_PROXY=
# WECHAT_WEBHOOK_URL=

# ── LLM 多渠道（填入 Key 后自动启用，也可在前端设置页配置） ──
LLM_CHANNELS=siliconflow,anspire
LLM_SILICONFLOW_URL=https://api.siliconflow.cn/v1/chat/completions
LLM_SILICONFLOW_KEY=
LLM_SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V4-Flash
LLM_ANSPIRE_URL=https://open-gateway.anspire.cn/v6/chat/completions
LLM_ANSPIRE_KEY=
LLM_ANSPIRE_MODEL=deepseek-v4-flash
ERNIE_BATCH_SIZE=10
LLM_MONTHLY_BUDGET=15
